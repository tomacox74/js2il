    </EmbeddedResource>
    <EmbeddedResource Include="built-ins\AsyncGeneratorFunction\JavaScript\AsyncGeneratorFunction_length.js">
      <LogicalName>Js2IL.Test262.Tests.built_ins.AsyncGeneratorFunction.JavaScript.AsyncGeneratorFunction_length.js</LogicalName>
