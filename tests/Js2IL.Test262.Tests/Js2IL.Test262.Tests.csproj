<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <IsPackable>false</IsPackable>
    <EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\..\scripts\test262\bootstrap.js">
      <LogicalName>Js2IL.Test262.Tests.Integration.JavaScript.Compile_Scripts_Test262Bootstrap.js</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\..\scripts\test262\metadataParser.js">
      <LogicalName>Js2IL.Test262.Tests.Integration.JavaScript.test262.metadataParser.js</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Integration\JavaScript\test262MetadataParser_testHarness.js">
      <LogicalName>Js2IL.Test262.Tests.Integration.JavaScript.Compile_Scripts_Test262MetadataParser.js</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="language\expressions\arrow-function\JavaScript\ArrowFunction_restricted-properties.js">
      <LogicalName>Js2IL.Test262.Tests.language.expressions.arrow_function.JavaScript.ArrowFunction_restricted-properties.js</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="language\expressions\arrow-function\JavaScript\ArrowFunction_cannot-override-this-with-thisArg.js">
