<Project>

  <PropertyGroup>
    <Js2ILPackageVersion Condition="'$(Js2ILPackageVersion)' == ''">0.9.0</Js2ILPackageVersion>
    <JavaScriptRuntimePackageVersion Condition="'$(JavaScriptRuntimePackageVersion)' == ''">$(Js2ILPackageVersion)</JavaScriptRuntimePackageVersion>
    <Js2ILSdkPackageVersion Condition="'$(Js2ILSdkPackageVersion)' == ''">$(JavaScriptRuntimePackageVersion)</Js2ILSdkPackageVersion>
  </PropertyGroup>

</Project>
