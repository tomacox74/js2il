  "support": {
    "entries": [
      {
        "clause": "23.2",
        "feature": "ArrayBuffer-backed TypedArray subset",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-typedarray-objects",
        "testScripts": [
          "Js2IL.Tests/TypedArray/JavaScript/ArrayBuffer_IsView_TypedArrays.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Construct_ArrayBuffer_ViewProperties.js",
          "Js2IL.Tests/TypedArray/JavaScript/Uint8Array_Construct_ArrayLike_Buffer_Search.js",
          "Js2IL.Tests/TypedArray/JavaScript/Float64Array_Construct_ArrayBuffer_Search.js"
        ],
        "notes": "JS2IL now provides a shared ArrayBuffer-backed TypedArray implementation for Int32Array, Uint8Array, and Float64Array, including static from/of helpers, shared iterator surfaces, core transform/search helpers, and buffer-backed view semantics. The full %TypedArray% constructor hierarchy, detached-buffer semantics, species hooks, and many prototype metadata/details are still incomplete."
      },
      {
        "clause": "23.2.5.1",
        "feature": "Int32Array constructors and preserved compiler fast paths",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-typedarray",
        "testScripts": [
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Construct_Length.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_FromArray_CopyAndCoerce.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Construct_ArrayBuffer_ViewProperties.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Construct_ArrayBuffer_Alignment_RangeError.js"
        ],
        "notes": "Int32Array supports length, array-like/typed-array copy, ArrayBuffer view construction, and static Int32Array.from/of helpers while keeping existing compiler-specialized member/index access entry points intact. Detached-buffer semantics, species construction, and constructor metadata/prototype parity remain incomplete."
      },
      {
        "clause": "23.2.5.1",
        "feature": "Uint8Array constructors",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-typedarray",
        "testScripts": [
          "Js2IL.Tests/TypedArray/JavaScript/Uint8Array_Construct_ArrayLike_Buffer_Search.js"
        ],
        "notes": "Uint8Array supports length, array-like, and ArrayBuffer-backed construction plus static Uint8Array.from/of helpers with Uint8 coercion and shared TypedArray view metadata. Uint8ClampedArray and full constructor metadata/prototype parity remain out of scope."
      },
      {
        "clause": "23.2.5.1",
        "feature": "Float64Array constructors",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-typedarray",
        "testScripts": [
          "Js2IL.Tests/TypedArray/JavaScript/Float64Array_Construct_ArrayBuffer_Search.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Construct_ArrayBuffer_Alignment_RangeError.js"
        ],
        "notes": "Float64Array supports length, array-like, and ArrayBuffer-backed construction plus static Float64Array.from/of helpers with IEEE-754 storage and shared TypedArray view metadata. BigInt-typed families and full constructor metadata/prototype parity remain incomplete."
      },
      {
        "clause": "23.2.8",
        "feature": "Shared typed array instance properties and indexed element access",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-properties-of-typedarray-instances",
        "testScripts": [
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Construct_ArrayBuffer_ViewProperties.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Subarray_ViewSemantics.js",
          "Js2IL.Tests/TypedArray/JavaScript/Uint8Array_Construct_ArrayLike_Buffer_Search.js",
          "Js2IL.Tests/TypedArray/JavaScript/Float64Array_Construct_ArrayBuffer_Search.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Index_Assign.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Wrapping_Semantics.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_NaN_Index_NoOp.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Infinity_Index_NoOp.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Fractional_Index_NoOp.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_ShiftDerived_Index_Access.js"
        ],
        "notes": "buffer, byteOffset, byteLength, length, numeric index access, and instance BYTES_PER_ELEMENT reads are shared across the supported TypedArray families, backed by ArrayBuffer views. Out-of-range reads and writes, detached buffers, and full property-descriptor/prototype fidelity are not fully spec-complete."
      },
      {
        "clause": "23.2.3.1",
        "feature": "Shared %TypedArray%.prototype.at/includes/indexOf/lastIndexOf",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-%typedarray%.prototype.at",
        "testScripts": [
          "Js2IL.Tests/TypedArray/JavaScript/Uint8Array_Construct_ArrayLike_Buffer_Search.js",
          "Js2IL.Tests/TypedArray/JavaScript/Float64Array_Construct_ArrayBuffer_Search.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Fill_Reverse_Join_LastIndexOf.js"
        ],
        "notes": "The supported TypedArray families share at(), includes(), indexOf(), and lastIndexOf() implementations with numeric coercion and NaN handling for includes(). at() still returns numeric defaults rather than fully spec-accurate undefined behavior for every out-of-range case."
      },
      {
        "clause": "23.2.3.26",
        "feature": "Shared %TypedArray%.prototype.set(source[, offset])",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-%typedarray%.prototype.set",
        "testScripts": [
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Set_FromArray_WithOffset.js",
          "Js2IL.Tests/TypedArray/JavaScript/Int32Array_Set_BoundsChecks.js"
        ],
        "notes": "set() supports array-like and typed-array sources, explicit offsets, bounds checks, and overlap-safe copying for the supported families. Species/detached-buffer semantics and broader TypedArray interoperability are still limited."
      },
      {
        "clause": "23.2.3.27",
