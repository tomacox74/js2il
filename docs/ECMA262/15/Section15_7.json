        "status": "Supported",
        "specUrl": "https://tc39.es/ecma262/#sec-class-definitions",
        "testScripts": [
          "tests/Jroc.Tests/Classes/JavaScript/Classes_ClassMethod_AccessGlobalVariable_Log.js",
