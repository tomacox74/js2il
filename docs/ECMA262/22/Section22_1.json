  "support": {
    "entries": [
      {
        "clause": "22.1.1",
        "feature": "String constructor (call/new)",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-string-constructor",
        "testScripts": [
          "Js2IL.Tests/String/JavaScript/String_New_Sugar.js"
        ],
        "notes": "new String(x) and String(x) are treated as sugar for DotNet2JSConversions.ToString without creating wrapper String objects; primitive string is returned and no [[StringData]]/boxed behaviors are exposed."
      },
      {
        "clause": "22.1.1.1",
        "feature": "String ( value )",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-string-constructor-string-value",
        "testScripts": [
          "Js2IL.Tests/String/JavaScript/String_New_Sugar.js"
        ],
        "notes": "Runtime coercion follows DotNet2JSConversions.ToString and always returns a primitive string; wrapper object semantics (property attributes, prototype chain) are not implemented."
      },
      {
        "clause": "22.1.2.1",
        "feature": "String.fromCharCode",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-string.fromcharcode",
        "testScripts": [
          "Js2IL.Tests/String/JavaScript/String_FromCharCode_Basic.js",
          "Js2IL.Tests/Array/JavaScript/Array_Slice_FromCharCode_Apply.js"
        ],
        "notes": "Implemented via JavaScriptRuntime.String.FromCharCode and exposed on GlobalThis.String.fromCharCode. Supports ToNumber coercion and ToUint16 code-unit truncation for single and variadic arguments. Does not aim to match all edge-case observable behaviors (e.g., exotic receivers, property attributes) beyond common library usage."
      },
      {
        "clause": "22.1.2.2",
        "feature": "String.fromCodePoint",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-string.fromcodepoint",
        "notes": "Implemented in JavaScriptRuntime.String.FromCodePoint and exposed on GlobalThis.String.fromCodePoint. Supports integer Unicode scalar values and throws RangeError for invalid code points; boxed String wrapper edge cases are still not modeled.",
        "testScripts": [
          "Js2IL.Tests/String/JavaScript/String_NewApis_Basic.js"
        ]
      },
      {
        "clause": "22.1.2.3",
        "feature": "String.prototype object",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-string.prototype",
        "notes": "GlobalThis.String.prototype is now exposed as a shared runtime object. Primitive string property reads consult that prototype surface for methods like constructor, toString, valueOf, at, and @@iterator, but js2il still does not create observable boxed String wrapper objects.",
        "testScripts": [
          "Js2IL.Tests/String/JavaScript/String_Prototype_Iterator_Surface.js"
        ]
      },
      {
        "clause": "22.1.2.4",
        "feature": "String.raw",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-string.raw",
        "notes": "Implemented in JavaScriptRuntime.String.Raw and exposed as GlobalThis.String.raw. Supports array-like template.raw values used by tagged-template helpers, but does not attempt full spec fidelity for exotic template objects or property attributes.",
        "testScripts": [
          "Js2IL.Tests/String/JavaScript/String_NewApis_Basic.js"
        ]
      },
      {
        "clause": "22.1.3.1",
        "feature": "String.prototype.at",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-string.prototype.at",
        "notes": "Implemented in JavaScriptRuntime.String.At with negative-index support and exposed both through string fast paths and String.prototype. Out-of-range results surface as js2il's undefined/null representation rather than a boxed wrapper value.",
        "testScripts": [
          "Js2IL.Tests/String/JavaScript/String_NewApis_Basic.js",
          "Js2IL.Tests/String/JavaScript/String_Prototype_Iterator_Surface.js"
        ]
      },
      {
        "clause": "22.1.3.2",
        "feature": "String.prototype.charAt",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-string.prototype.charat",
        "testScripts": [
          "Js2IL.Tests/String/JavaScript/String_CharAt_Basic.js"
        ],
        "notes": "Implemented via JavaScriptRuntime.String.CharAt and exposed on the shared String.prototype surface while retaining direct string fast paths. js2il still skips boxed String wrapper semantics and full exotic-property observability."
      },
      {
        "clause": "22.1.3.3",
        "feature": "String.prototype.charCodeAt",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-string.prototype.charcodeat",
        "testScripts": [
          "Js2IL.Tests/String/JavaScript/String_CharCodeAt_Basic.js"
        ],
        "notes": "Implemented in JavaScriptRuntime.String.CharCodeAt and exposed on the shared String.prototype surface. Returns a boxed number and preserves js2il's current undefined/null modeling rather than full boxed-wrapper semantics."
      },
      {
        "clause": "22.1.3.4",
        "feature": "String.prototype.codePointAt",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-string.prototype.codepointat",
        "notes": "Implemented in JavaScriptRuntime.String.CodePointAt with surrogate-pair decoding for valid leading surrogates. Out-of-range results use js2il's undefined/null representation and boxed String wrapper edge cases remain unsupported.",
