          "tests/Jroc.Tests/ControlFlow/JavaScript/ControlFlow_TryCatchFinally_ThrowValue.js",
          "tests/Jroc.Tests/ControlFlow/JavaScript/ControlFlow_TryFinally_Return.js"
        ],
        "notes": "Core completion behavior is represented by emitted control flow and exception handling, not as first-class Completion Record values."
      },
      {
        "clause": "6.2.5",
        "feature": "Reference records (GetValue/PutValue for identifiers and members)",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-reference-record-specification-type",
        "testScripts": [
          "tests/Jroc.Tests/Object/JavaScript/Object_AssignmentExpression_PropertySet_ResultStoredToScopeField.js",
