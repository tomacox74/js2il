          "tests/Jroc.Test262.Tests/language/expressions/assignment/PortExpressionsBatchExecutionTests.cs",
          "tests/Jroc.Test262.Tests/language/expressions/call/PortExpressionsBatchExecutionTests.cs",
          "tests/Jroc.Test262.Tests/language/expressions/member-expression/PortExpressionsBatchExecutionTests.cs"
        ],
        "notes": "Identifier/member references work for supported language forms, including the covered test262 GetValue/PutValue cases for computed members, null/undefined member bases, and function-call reference resolution. Spec-exact modeling of every Reference Record variant remains incomplete."
      },
      {
        "clause": "6.2.6",
        "feature": "Property descriptor specification type",
        "status": "Supported with Limitations",
        "specUrl": "https://tc39.es/ecma262/#sec-property-descriptor-specification-type",
        "testScripts": [
