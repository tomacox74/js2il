<Project>

  <PropertyGroup>
    <Js2ILCompileOnBuild Condition="'$(Js2ILCompileOnBuild)' == ''">true</Js2ILCompileOnBuild>
    <Js2ILOutputRoot Condition="'$(Js2ILOutputRoot)' == ''">$([System.IO.Path]::Combine('$(IntermediateOutputPath)', 'js2il'))</Js2ILOutputRoot>
    <Js2ILRootModuleId Condition="'$(Js2ILRootModuleId)' == ''"></Js2ILRootModuleId>
    <Js2ILModuleResolutionBaseDirectory Condition="'$(Js2ILModuleResolutionBaseDirectory)' == ''">$(MSBuildProjectDirectory)</Js2ILModuleResolutionBaseDirectory>
    <Js2ILReferenceOutputAssembly Condition="'$(Js2ILReferenceOutputAssembly)' == ''">true</Js2ILReferenceOutputAssembly>
    <Js2ILCopyToOutputDirectory Condition="'$(Js2ILCopyToOutputDirectory)' == ''">false</Js2ILCopyToOutputDirectory>
    <Js2ILEmitPdb Condition="'$(Js2ILEmitPdb)' == '' and '$(Configuration)' == 'Debug'">true</Js2ILEmitPdb>
    <Js2ILEmitPdb Condition="'$(Js2ILEmitPdb)' == ''">false</Js2ILEmitPdb>
    <Js2ILAnalyzeUnused Condition="'$(Js2ILAnalyzeUnused)' == ''">false</Js2ILAnalyzeUnused>
    <Js2ILVerbose Condition="'$(Js2ILVerbose)' == ''">false</Js2ILVerbose>
    <Js2ILStrictMode Condition="'$(Js2ILStrictMode)' == ''">Error</Js2ILStrictMode>
    <Js2ILDiagnosticFilePath Condition="'$(Js2ILDiagnosticFilePath)' == ''"></Js2ILDiagnosticFilePath>
  </PropertyGroup>

</Project>
